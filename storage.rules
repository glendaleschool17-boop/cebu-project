rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Payment proofs — only the backend (Admin SDK) uploads these.
    // Authenticated users can read their own proof via a direct URL
    // (the URL is stored in Firestore which is already secured).
    // We make them publicly readable so admins can view images in-browser.
    match /payment-proofs/{filename} {
      allow read:  if true;   // URL is only known if you have the booking record
      allow write: if false;  // Backend Admin SDK only
    }

    // GCash QR — public read, backend write only
    match /gcash-qr/{filename} {
      allow read:  if true;
      allow write: if false;
    }

    // Block all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
